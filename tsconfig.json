{
  "compilerOptions": {
    "target": "ES2022",                        
    "module": "CommonJS",
    "lib": ["ES2022"],
    "strict": true,                            
    "esModuleInterop": true,                   
    "forceConsistentCasingInFileNames": true,  
    "skipLibCheck": true,                      
    "outDir": "dist",                          
    "rootDir": "src",                          
    "moduleResolution": "node",
    "resolveJsonModule": true                  
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}